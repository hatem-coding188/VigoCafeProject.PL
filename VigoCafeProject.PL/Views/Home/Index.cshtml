
@{
    Layout = "~/Views/_Layout.cshtml";
    ViewData["Title"] = "Home";
}

@using DAL.Models
@using System.Collections.Generic

<!-- Hero Section -->
<section class="hero">
    <div class="hero-content">
        <h1>Welcome to <span>Vigo Cafe</span> ☕️</h1>
        <p>Step into a world of warmth, flavor, and comfort. At our café, every cup is brewed with passion, and every bite is crafted to delight. Whether you’re here for your morning coffee, a cozy afternoon break, or a sweet treat with friends, we’re dedicated to making your experience special.Relax, savor, and enjoy the perfect blend of taste and atmosphere — your happy place starts here.</p>
        <div class="hero-buttons">
            <a href="/Menu" class="btn-primary">Explore Menu</a>
        </div>
    </div>
</section>

<!-- Featured Products -->
<section class="featured-section">
    <div class="features-container">
        <div class="section-header" style="grid-column: 1 / -1;">
            <h2> <span>Featured</span></h2>
            <p>Hand-picked favorites just for you</p>
        </div>
        @foreach (var product in (IEnumerable<Product>)ViewBag.FeaturedProducts)
        {
            <div class="feature-card">
                <img src="@product.ImageUrl" alt="@product.Name"
                     style="width:100%; height:150px; object-fit:cover; border-radius:8px; margin-bottom:15px;" />
                <h3>@product.Name</h3>
                <p>@product.Description</p>
                <p style="color:#E8610A; font-weight:700; margin-top:10px;">@product.Price SAR</p>
            </div>
        }
    </div>
</section>

<!-- Latest Products -->
<section class="featured-section" style="background-color:#1a1a1a;">
    <div class="features-container">
        <div class="section-header" style="grid-column: 1 / -1;">
            <h2><span>Latest</span></h2>
            <p>Fresh additions to our menu</p>
        </div>
        @foreach (var product in (IEnumerable<Product>)ViewBag.LatestProducts)
        {
            <div class="feature-card">
                <img src="@product.ImageUrl" alt="@product.Name"
                     style="width:100%; height:150px; object-fit:cover; border-radius:8px; margin-bottom:15px;" />
                <h3>@product.Name</h3>
                <p>@product.Description</p>
                <p style="color:#E8610A; font-weight:700; margin-top:10px;">@product.Price SAR</p>
            </div>
        }
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section">
    <div class="cta-content">
        <h2>Ready to Order?</h2>
        <p>Browse our full menu and enjoy the best coffee in town</p>
        <a href="/Menu" class="btn-primary">View Full Menu</a>
    </div>
</section>