@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vips Cafe</title>

    <!-- CSS -->
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet" />
</head>
<body>

    <!-- ===== HEADER ===== -->
    <header class="cafe-header">
        <div class="header-container">

            <a href="/Home" class="logo">
                <span class="logo-text">Vips</span>
                <span class="logo-cafe">Cafe</span>
            </a>

            <nav class="navbar">
                <ul class="nav-links" id="navLinks">
                    <li><a href="/Home">Home</a></li>
                    <li><a href="/Menu">Menu</a></li>
                    <li><a href="/Cart"><i class="fas fa-shopping-cart"></i> Cart</a></li>
                    <li><a href="/Account/Login">Login</a></li>
                    <li><a href="/Account/Register">Register</a></li>
                    <li>
                       @if (HttpContextAccessor.HttpContext.Session.GetString("UserRole") == "Admin")
                            {
                            <a href="/Admin">Admin</a>
                            }
                    </li>
                </ul>
            </nav>

            <div class="hamburger" onclick="toggleMenu()">
                <span></span>
                <span></span>
                <span></span>
            </div>

        </div>
    </header>

    <!-- ===== PAGE CONTENT ===== -->
    <main>
        @RenderBody()
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="cafe-footer">
        <div class="footer-container">

            <div class="footer-section">
                <div class="footer-logo">
                    <span class="logo-text">Vips</span>
                    <span class="logo-cafe">Cafe</span>
                </div>
                <p class="footer-desc">A cozy place for great coffee, pastries & good vibes.</p>
            </div>

            <div class="footer-section">
                <h3 class="footer-title">Quick Links</h3>
                <ul class="footer-links">
                    <li><a href="/Home">Home</a></li>
                    <li><a href="/Menu">Menu</a></li>
                    <li><a href="/Account/Login">Login</a></li>
                    <li><a href="/Account/Register">Register</a></li>
                </ul>
            </div>

            <div class="footer-section">
                <h3 class="footer-title">Contact Us</h3>
                <ul class="footer-contact">
                    <li><i class="fas fa-phone"></i> +966 5X XXX XXXX</li>
                    <li><i class="fas fa-envelope"></i> info@vipscafe.com</li>
                    <li><i class="fas fa-map-marker-alt"></i> Riyadh, Saudi Arabia</li>
                </ul>
            </div>

            <div class="footer-section">
                <h3 class="footer-title">Follow Us</h3>
                <div class="social-icons">
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-snapchat"></i></a>
                </div>
            </div>

        </div>

        <div class="footer-bottom">
            <p>© 2026 Vips Cafe. All rights reserved.</p>
        </div>
    </footer>

    <!-- ===== JS ===== -->
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>