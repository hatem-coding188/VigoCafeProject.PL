@model DAL.Models.Subcategory

@{
    Layout = "~/Views/_Layout.cshtml";
    ViewData["Title"] = "Edit Subcategory";
}

<section class="admin-section">
    <div class="admin-container">

        <div class="admin-header">
            <h2 class="admin-title">Edit <span>Subcategory</span></h2>
            <a href="/Admin/Subcategories" class="btn-back">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        <div class="admin-form-card">
            <form method="post" action="/Admin/EditSubcategory">
                @Html.AntiForgeryToken()

                <input type="hidden" name="Id" value="@Model.Id" />

                <div class="form-group">
                    <label>Subcategory Name</label>
                    <div class="input-wrapper">
                        <i class="fas fa-list"></i>
                        <input type="text" name="Name"
                               value="@Model.Name"
                               placeholder="Enter subcategory name" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>Category</label>
                    <div class="input-wrapper">
                        <i class="fas fa-layer-group"></i>
                        <select name="CategoryId" required>
                            @foreach (var cat in ViewBag.Categories)
                            {
                                <option value="@cat.Id"
                                    @(cat.Id == Model.CategoryId ? "selected" : "")>
                                    @cat.Name
                                </option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>
                        <input type="checkbox" name="IsActive" value="true"
                        @(Model.IsActive ? "checked" : "") /> Active
                    </label>
                </div>

                <button type="submit" class="btn-auth">Save Changes</button>
            </form>
        </div>

    </div>
</section>