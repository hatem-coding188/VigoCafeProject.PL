@model IEnumerable<DAL.Models.Order>

@{
    Layout = "~/Views/_Layout.cshtml";
    ViewData["Title"] = "Orders";
}

<section class="admin-section">
    <div class="admin-container">

        <h2 class="admin-title">Orders</h2>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Total</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Update Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.Id</td>
                        <td>@order.Customer.FullName</td>
                        <td>@order.TotalAmount SAR</td>
                        <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            <span class="status-badge status-@order.Status.ToString().ToLower()">
                                @order.Status
                            </span>
                        </td>
                        <td>
                            <select onchange="updateStatus(@order.Id, this.value)" class="status-select">
                                @foreach (var status in Enum.GetValues(typeof(DAL.Models.OrderStatus)))
                                {
                                    <option value="@status" @(order.Status.ToString() == status.ToString() ? "selected" : "")>
                                        @status
                                    </option>
                                }
                            </select>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</section>

@section Scripts {
    <script>
        function updateStatus(orderId, status) {
            window.location.href = `/Admin/UpdateOrderStatus?id=${orderId}&status=${status}`;
        }
    </script>
}