@{
    Layout = "~/Views/_Layout.cshtml";
    ViewData["Title"] = "Add Subcategory";
}

<section class="admin-section">
    <div class="admin-container">

        <div class="admin-header">
            <h2 class="admin-title">Add <span>Subcategory</span></h2>
            <a href="/Admin/Subcategories" class="btn-back">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        <div class="admin-form-card">
            <form method="post" action="/Admin/AddSubcategory">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label>Subcategory Name</label>
                    <div class="input-wrapper">
                        <i class="fas fa-list"></i>
                        <input type="text" name="Name" placeholder="Enter subcategory name" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>Image URL</label>
                    <div class="input-wrapper">
                        <i class="fas fa-image"></i>
                        <input type="text" name="ImageUrl" placeholder="Enter image path" />
                    </div>
                </div>


                <div class="form-group">
                    <label>Category</label>
                    <div class="input-wrapper">
                        <i class="fas fa-layer-group"></i>
                        <select name="CategoryId" required>
                            @foreach (var cat in ViewBag.Categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>
                        <input type="checkbox" name="IsActive" value="true" checked /> Active
                    </label>
                </div>

                <button type="submit" class="btn-auth">Add Subcategory</button>
            </form>
        </div>

    </div>
</section>