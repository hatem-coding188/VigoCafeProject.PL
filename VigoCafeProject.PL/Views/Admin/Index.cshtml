@{
    Layout = "~/Views/_Layout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
}

<section class="admin-section">
    <div class="admin-container">

        <h2 class="admin-title">Admin <span>Dashboard</span></h2>

        <!-- Stats -->
        <div class="admin-stats">
            <div class="stat-card">
                <i class="fas fa-list"></i>
                <h3>@ViewBag.Categories</h3>
                <p>Categories</p>
                <a href="/Admin/Categories" class="btn-admin">Manage</a>
            </div>
            <div class="stat-card">
                <i class="fas fa-coffee"></i>
                <h3>@ViewBag.Products</h3>
                <p>Products</p>
                <a href="/Admin/Products" class="btn-admin">Manage</a>
            </div>
            <div class="stat-card">
                <i class="fas fa-shopping-bag"></i>
                <h3>@ViewBag.Orders</h3>
                <p>Orders</p>
                <a href="/Admin/Orders" class="btn-admin">Manage</a>
            </div>
        </div>

    </div>
</section>