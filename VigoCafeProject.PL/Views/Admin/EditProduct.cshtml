@model DAL.Models.Product

@{
    Layout = "~/Views/_Layout.cshtml";
    ViewData["Title"] = "Edit Product";
}

<section class="admin-section">
    <div class="admin-container">

        <div class="admin-header">
            <h2 class="admin-title">Edit <span>Product</span></h2>
            <a href="/Admin/Products" class="btn-back">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        <div class="admin-form-card">
            <form method="post" action="/Admin/EditProduct">
                @Html.AntiForgeryToken()

                <input type="hidden" name="Id" value="@Model.Id" />

                <div class="form-group">
                    <label>Product Name</label>
                    <div class="input-wrapper">
                        <i class="fas fa-coffee"></i>
                        <input type="text" name="Name"
                               value="@Model.Name"
                               placeholder="Enter product name" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <div class="input-wrapper">
                        <i class="fas fa-align-left"></i>
                        <input type="text" name="Description"
                               value="@Model.Description"
                               placeholder="Enter description" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Price (SAR)</label>
                    <div class="input-wrapper">
                        <i class="fas fa-tag"></i>
                        <input type="number" name="Price" step="0.01"
                               value="@Model.Price"
                               placeholder="0.00" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>Image URL</label>
                    <div class="input-wrapper">
                        <i class="fas fa-image"></i>
                        <input type="text" name="ImageUrl"
                               value="@Model.ImageUrl"
                               placeholder="Enter image path" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Subcategory</label>
                    <div class="input-wrapper">
                        <i class="fas fa-layer-group"></i>
                        <select name="SubcategoryId">
                            @foreach (var sub in ViewBag.Subcategories)
                            {
                                <option value="@sub.Id"
                                        @(sub.Id == Model.SubcategoryId ? "selected" : "")>
                                    @sub.Name
                                </option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-group checkbox-group">
                    <label>
                        <input type="checkbox" name="IsAvailable" value="true"
                               @(Model.IsAvailable ? "checked" : "") /> Available
                    </label>
                    <label>
                        <input type="checkbox" name="IsFeatured" value="true"
                               @(Model.IsFeatured ? "checked" : "") /> Featured
                    </label>
                </div>

                <button type="submit" class="btn-auth">Save Changes</button>
            </form>
        </div>

    </div>
</section>