@model DAL.Models.Category

@{
    Layout = "~/Views/_Layout.cshtml";
    ViewData["Title"] = "Edit Category";
}

<section class="admin-section">
    <div class="admin-container">

        <div class="admin-header">
            <h2 class="admin-title">Edit <span>Category</span></h2>
            <a href="/Admin/Categories" class="btn-back">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        <div class="admin-form-card">
            <form method="post" action="/Admin/EditCategory">
                @Html.AntiForgeryToken()

                <input type="hidden" name="Id" value="@Model.Id" />

                <div class="form-group">
                    <label>Category Name</label>
                    <div class="input-wrapper">
                        <i class="fas fa-list"></i>
                        <input type="text" name="Name"
                               value="@Model.Name"
                               placeholder="Enter category name" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>Image URL</label>
                    <div class="input-wrapper">
                        <i class="fas fa-image"></i>
                        <input type="text" name="ImageUrl"
                               value="@Model.ImageUrl"
                               placeholder="Enter image path" />
                    </div>
                </div>

                <div class="form-group">
                    <label>
                        <input type="checkbox" name="IsActive" value="true"
                        @(Model.IsActive ? "checked" : "") /> Active
                    </label>
                </div>

                <button type="submit" class="btn-auth">Save Changes</button>
            </form>
        </div>

    </div>
</section>